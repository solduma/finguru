# ---- Ollama Cloud (chat / inference) ----
# Native endpoint. OpenAI-compatible base is https://ollama.com/v1
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=replace-with-your-full-key-including-the-part-after-the-dot
OLLAMA_CHAT_MODEL=qwen3.5:cloud
# Reasoning models emit a long "thinking" block first; off = snappier replies.
OLLAMA_THINK=false

# ---- Embeddings (local, swappable) ----
# EMBEDDING_BACKEND: "local" (fastembed, default) or "ollama" (if your tier enables /api/embed)
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# ---- RAG / Chroma ----
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=finguru_lessons
RAG_TOP_K=5

# ---- Content ----
# Path (inside the api container / process) to the MDX lessons that get ingested.
CONTENT_DIR=../web/content

# ---- Server ----
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed to call the API (the Next.js dev server)
CORS_ORIGINS=http://localhost:3000
