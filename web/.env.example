# Web (Next.js) environment.
#
# Password gate (friends-only access). BOTH must be set to turn the gate ON.
# Leave them unset for open local dev. These are server-only (no NEXT_PUBLIC_
# prefix), so they are never exposed to the browser.
#
# SITE_PASSWORD: the shared password you give your friends.
# AUTH_SECRET:   a long random string used to sign the auth cookie. Generate one
#                with:  openssl rand -hex 32
SITE_PASSWORD=
AUTH_SECRET=

# Where the Next.js server proxies /api/* (the FastAPI backend). run.sh sets this
# automatically to the API port; for a standalone `next dev` point it manually.
# API_PROXY_TARGET=http://localhost:48000

# Show the chat tutor widget. Requires the Python RAG backend reachable via
# API_PROXY_TARGET. Leave unset/0 for a frontend-only deploy (e.g. Vercel).
# NEXT_PUBLIC_CHAT_ENABLED=1
