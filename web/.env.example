# Web (Next.js) environment.
#
# Password gate (friends-only access). BOTH must be set to turn the gate ON.
# Leave them unset for open local dev. These are server-only (no NEXT_PUBLIC_
# prefix), so they are never exposed to the browser.
#
# SITE_PASSWORD: the shared password you give your friends.
# AUTH_SECRET:   a long random string used to sign the auth cookie. Generate one
#                with:  openssl rand -hex 32
SITE_PASSWORD=
AUTH_SECRET=

# Where the Next.js server proxies /api/* (the FastAPI backend). Defaults to
# http://localhost:8000 for local dev.
# API_PROXY_TARGET=http://localhost:8000
